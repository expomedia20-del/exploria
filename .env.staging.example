APP_NAME=EXPLORIA
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

APP_LOCALE=fa
APP_FALLBACK_LOCALE=fa
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=exploria_staging
DB_USERNAME=exploria_staging
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@exploria.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

OTP_DRIVER=http
OTP_FIXED_CODE=
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_HTTP_ENDPOINT=
OTP_HTTP_TOKEN=
OTP_HTTP_TIMEOUT_SECONDS=5
OTP_HTTP_SENDER=EXPLORIA
